{
  "mode": "free",
  "gdelt": {
    "enabled": false,
    "query": "(\"artificial intelligence\" OR \"generative AI\" OR \"large language model\" OR OpenAI OR Anthropic OR DeepSeek OR NVIDIA)",
    "timespan": "1d",
    "max_items": 50
  },
  "arxiv": {
    "enabled": true,
    "query": "cat:cs.AI OR cat:cs.LG OR cat:cs.CL OR cat:cs.RO",
    "max_items": 50
  },
  "hackernews": {
    "enabled": true,
    "scan_items": 250,
    "max_items": 50,
    "keywords": [
      "AI",
      "LLM",
      "OpenAI",
      "Anthropic",
      "DeepSeek",
      "NVIDIA",
      "robotics",
      "agent",
      "machine learning",
      "inference",
      "model"
    ]
  },
  "reddit": {
    "enabled": true,
    "max_items_per_community": 12,
    "communities": [
      "MachineLearning",
      "LocalLLaMA",
      "artificial",
      "OpenAI",
      "singularity",
      "robotics",
      "StableDiffusion",
      "LanguageTechnology",
      "MLQuestions",
      "ChatGPT"
    ]
  },
